# =============================================================================
# FAAS4U — Laprophan | Variables d'Environnement
# Fichier  : .env.example
# Rôle     : Template pour configurer les variables d'environnement locales.
#            Les clés de développement doivent être renseignées dans `.env`
#            qui est ignoré par Git (sécurité BPF).
# =============================================================================

# Clé API Anthropic (Claude)
# À récupérer sur https://console.anthropic.com/
ANTHROPIC_API_KEY=votre_cle_api_sk_ant_...

# Environnement de développement (dev, test, prod)
APP_ENV=dev

# IMPORTANT : 
# 1. Copiez ce fichier et renommez-le en ".env"
# 2. Renseignez vos vraies clés dans le ".env"
# 3. Ne commitez JAMAIS le ".env" sur GitHub !
